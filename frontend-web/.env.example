# Public API base for Next.js client calls
NEXT_PUBLIC_API_URL=http://localhost:8000

# Full URLs for shop admin (footer). Main site uses /login and /register on this app.
# Omit in development to use http://localhost:3000/admin/login and .../admin/register (override NEXT_PUBLIC_APP_ORIGIN if not on :3000).
NEXT_PUBLIC_ADMIN_SIGNIN_URL=http://localhost:3000/admin/login
NEXT_PUBLIC_ADMIN_REGISTER_URL=http://localhost:3000/admin/register

# Public support (Contact page)
NEXT_PUBLIC_SUPPORT_EMAIL=support@lenscart.com
NEXT_PUBLIC_SUPPORT_PHONE=+91 80 0000 0000
