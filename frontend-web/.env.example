# Public API base for Next.js client calls
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public support (Contact page)
NEXT_PUBLIC_SUPPORT_EMAIL=support@evisionpvtltd.com
NEXT_PUBLIC_SUPPORT_PHONE=+91 80 0000 0000

# Shop admin (footer / FAQ). Omit both to use same-origin /admin/login and /admin/register.
# For local absolute links only; production: set to your public site origin or leave unset.
NEXT_PUBLIC_ADMIN_SIGNIN_URL=http://localhost:3000/admin/login
NEXT_PUBLIC_ADMIN_REGISTER_URL=http://localhost:3000/admin/register
