# Server
PORT=8000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# AWS / Storage
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=replace_me
AWS_SECRET_ACCESS_KEY=replace_me
AWS_S3_BUCKET=evision-uploads
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=
CLOUDFRONT_DOMAIN=

# DynamoDB
DYNAMO_TABLE_PREFIX=evision
DYNAMODB_ENDPOINT=http://127.0.0.1:8001
DYNAMO_ENDPOINT=http://127.0.0.1:8001

# JWT
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=7d

# OTP / Twilio
OTP_CONSOLE_ONLY=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SMTP / Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=E Vision Pvt. Ltd.
EMAIL_FROM=

# Payments (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Push
FIREBASE_SERVICE_ACCOUNT_JSON=

# Shiprocket
SHIPROCKET_MOCK=true
SHIPROCKET_BASE_URL=https://apiv2.shiprocket.in
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=Primary
SHIPROCKET_WEBHOOK_TOKEN=

# Superadmin / seed
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SUPERADMIN_NAME=Super Admin
SUPERADMIN_PHONE=
