# Copy to `.env` and adjust. See deploy docs for production secrets.

JWT_SECRET=change-me-min-32-chars-for-production-use

MONGODB_URI=mongodb://127.0.0.1:27017/evision

# DynamoDB table prefix / AWS region as used by DynamoModule.

# Public catalogue: restrict storefront + cart to products owned by this approved admin row.
# Use a fixed UUID; on boot the backend ensures a matching synthetic `admins` row exists.
PLATFORM_CATALOG_ADMIN_ID=
# Display name for the synthetic platform shop (optional).
PLATFORM_SHOP_NAME=Evision India

SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

FRONTEND_URL=http://localhost:3000
