# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# AWS Credentials
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_S3_BUCKET=evision-uploads
# CloudFront distribution domain for fast image serving (no https://, no trailing slash)
# CLOUDFRONT_DOMAIN=xxxxxxxxxxxxxx.cloudfront.net

# DynamoDB (uses same AWS credentials above)
DYNAMO_TABLE_PREFIX=evision
# For local development with DynamoDB Local: http://localhost:8000
# DYNAMO_ENDPOINT=http://localhost:8000

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# Twilio OTP
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Nodemailer (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@evisionpvtltd.com
SMTP_PASS=your_app_password_here
EMAIL_FROM_NAME=E Vision Pvt. Ltd.
EMAIL_FROM=noreply@evisionpvtltd.com

# Superadmin (used only by seed script)
SUPERADMIN_EMAIL=superadmin@evisionpvtltd.com
SUPERADMIN_PASSWORD=SuperAdmin@2024!
SUPERADMIN_NAME=Super Admin
