# Copy to `.env` and adjust. See deploy docs for production secrets.

JWT_SECRET=change-me-min-32-chars-for-production-use

# Login / signup / password-reset OTP is sent by email (Nodemailer). Set SMTP + EMAIL_FROM for real delivery.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@example.com
# EMAIL_FROM_NAME=E vision Pvt. Ltd.
# Dev: log OTP only (no email) — unset or set to false in production when SMTP is configured.
# OTP_CONSOLE_ONLY=true

MONGODB_URI=mongodb://127.0.0.1:27017/evision

# DynamoDB table prefix / AWS region as used by DynamoModule.

# Public catalogue: restrict storefront + cart to products owned by this approved admin row.
# Use a fixed UUID; on boot the backend ensures a matching synthetic `admins` row exists.
PLATFORM_CATALOG_ADMIN_ID=
# Display name for the synthetic platform shop (optional).
PLATFORM_SHOP_NAME=Evision India

SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

FRONTEND_URL=http://localhost:3000

# Contact form API (`POST /contact/message`, `POST /contact/newsletter`) — where staff/marketing receive submissions.
# CONTACT_FORM_TO_EMAIL=support@evisionindia.com
# CONTACT_NEWSLETTER_TO_EMAIL=marketing@evisionindia.com
# PUBLIC_SUPPORT_EMAIL=support@evisionindia.com
# PUBLIC_MARKETING_EMAIL=marketing@evisionindia.com

# Public contact lines (optional; web/mobile contact UI also reads NEXT_PUBLIC_* / EXPO_PUBLIC_*).
# NEXT_PUBLIC_INFO_EMAIL=info@evisionindia.com
