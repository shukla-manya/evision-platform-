# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Local AWS (DynamoDB Local + MinIO) — default for development ─────────────
# Start stack:  docker compose -f docker-compose.local.yml up -d
# Then:         npm run setup:tables && npm run seed:superadmin
#
DYNAMODB_ENDPOINT=http://localhost:8000
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_BASE_URL=http://localhost:9000/evision-uploads
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET=evision-uploads

# ─── Real AWS (comment out the block above and use these) ─────────────────────
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here
# AWS_S3_BUCKET=evision-uploads
# Leave DYNAMODB_ENDPOINT and S3_ENDPOINT unset to use AWS DynamoDB + S3.

# CloudFront (production only; leave unset for local)
# CLOUDFRONT_DOMAIN=xxxxxxxxxxxxxx.cloudfront.net

DYNAMO_TABLE_PREFIX=evision

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# Twilio OTP
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Nodemailer (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@evisionpvtltd.com
SMTP_PASS=your_app_password_here
EMAIL_FROM_NAME=E Vision Pvt. Ltd.
EMAIL_FROM=noreply@evisionpvtltd.com

# Superadmin (used only by seed script)
SUPERADMIN_EMAIL=superadmin@evisionpvtltd.com
SUPERADMIN_PASSWORD=SuperAdmin@2024!
SUPERADMIN_NAME=Super Admin
