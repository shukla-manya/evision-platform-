{
  "name": "evision-backend",
  "version": "0.1.0",
  "description": "E Vision Platform — Multi-Shop E-Commerce + Electrician Service",
  "author": "Manya Shukla",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "setup:tables": "ts-node -r tsconfig-paths/register src/seeds/dynamo-tables.setup.ts",
    "seed:superadmin": "ts-node -r tsconfig-paths/register src/seeds/superadmin.seed.ts",
    "seed:perf": "ts-node -r tsconfig-paths/register src/seeds/perf-load.seed.ts",
    "test": "jest",
    "test:e2e": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 jest --config jest-e2e.config.js --runInBand --forceExit",
    "test:e2e:http": "NODE_NO_WARNINGS=1 npx ts-node --transpile-only -r tsconfig-paths/register test/e2e/http-e2e-runner.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.540.0",
    "@aws-sdk/client-s3": "^3.540.0",
    "@aws-sdk/lib-dynamodb": "^3.540.0",
    "@aws-sdk/s3-request-presigner": "^3.540.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/throttler": "^5.1.2",
    "@nestjs/websockets": "^10.4.22",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "firebase-admin": "^13.8.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.18.0",
    "razorpay": "^2.9.6",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "twilio": "^5.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@types/archiver": "^6.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.0",
    "@types/nodemailer": "^6.4.14",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.17.6",
    "@nestjs/testing": "^10.3.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "dynalite": "^4.0.0",
    "supertest": "^7.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.3"
  }
}
