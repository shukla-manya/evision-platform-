# Public API base URL consumed by Expo app at build/runtime.
EXPO_PUBLIC_API_URL=http://localhost:8000

# Shop registration on the public web (admin app points users here before first app sign-in)
EXPO_PUBLIC_SHOP_REGISTER_URL=http://localhost:3000/admin/register

# Optional: storefront origin for FAQ / privacy links in the app. If unset, derived from EXPO_PUBLIC_SHOP_REGISTER_URL.
# EXPO_PUBLIC_WEB_ORIGIN=http://localhost:3000

# Lettermark above the in-app Shop catalogue header (matches web NEXT_PUBLIC_SHOP_BRAND_MARK).
# EXPO_PUBLIC_SHOP_BRAND_MARK=EVISION

# Optional contact overrides (defaults match web `lib/public-contact`).
# EXPO_PUBLIC_SALES_PHONE=+91-9811250806
# EXPO_PUBLIC_SUPPORT_PHONE=+91-9319183121
# EXPO_PUBLIC_MARKETING_EMAIL=marketing@evisionindia.com
# EXPO_PUBLIC_SUPPORT_EMAIL=support@evisionindia.com
# EXPO_PUBLIC_INFO_EMAIL=info@evisionindia.com
